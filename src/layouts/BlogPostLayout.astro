---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    author: string;
    pubDate: string;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;

const formattedDate = new Date(frontmatter.pubDate).toLocaleDateString('en-AU', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
});
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <!-- Post Hero -->
  <section class="post-hero">
    <div class="container post-hero-inner">
      <div class="post-meta">
        <a href="/blog" class="back-link">← Back to Blog</a>
        <time datetime={frontmatter.pubDate}>{formattedDate}</time>
      </div>
      <h1 class="post-title">{frontmatter.title}</h1>
      <p class="post-desc">{frontmatter.description}</p>
      <div class="post-author">
        <div class="author-avatar-sm" aria-hidden="true">E</div>
        <span>By <strong>{frontmatter.author}</strong></span>
      </div>
      {frontmatter.tags && (
        <div class="post-tags" aria-label="Tags">
          {frontmatter.tags.map((tag: string) => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
    <div class="post-hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none">
        <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#F5F1E8"/>
      </svg>
    </div>
  </section>

  <!-- Post Content -->
  <section style="background: #F5F1E8; padding: 4rem 0;">
    <div class="container post-layout">
      <article class="post-content prose">
        <slot />
      </article>

      <aside class="post-sidebar">
        <div class="sidebar-card">
          <h3>About the Author</h3>
          <div class="sidebar-author">
            <div class="author-avatar-lg" aria-hidden="true">E</div>
            <div>
              <p class="author-name-lg">Emchi Tsundu Dolma</p>
              <p class="author-role">Tibetan Medicine & Ayurveda Consultant</p>
            </div>
          </div>
          <p class="author-bio">Graduate of Men-Tsee-Khang, Dharamshala. 10+ years of experience in traditional Tibetan healing.</p>
          <a href="/about" class="sidebar-link">Read Full Bio →</a>
        </div>

        <div class="sidebar-card sidebar-cta">
          <p class="tibetan-script sidebar-tibetan">ནད་སེལ་མཁས་པ།</p>
          <h3>Ready to Heal?</h3>
          <p>Book a consultation with Emchi and begin your journey to balance.</p>
          <a href="/contact" class="btn btn-primary sidebar-btn" id="post-book-btn">Book Now</a>
          <a href="tel:+61458494785" class="sidebar-phone">📞 0458 494 785</a>
        </div>

        <div class="sidebar-card">
          <h3>More Articles</h3>
          <ul class="sidebar-links-list">
            <li><a href="/blog/introduction-to-tibetan-medicine">Introduction to Sowa Rigpa</a></li>
            <li><a href="/blog/understanding-the-three-nyepas">The Three Nyepas Explained</a></li>
            <li><a href="/blog/tibetan-pulse-diagnosis">Tibetan Pulse Diagnosis</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .post-hero { background: linear-gradient(135deg, #1B5E7F, #0F3D52); padding: 4.5rem 0 2rem; overflow: hidden; }
  .post-hero-inner { max-width: 760px; }
  .post-meta { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .back-link { color: rgba(255,255,255,0.7); font-size: 0.875rem; text-decoration: none; transition: color 0.2s; }
  .back-link:hover { color: #E8B44F; }
  .post-meta time { font-size: 0.875rem; color: rgba(255,255,255,0.55); }
  .post-title { font-family: 'Playfair Display', serif; font-size: clamp(1.75rem, 4vw, 2.75rem); color: white; line-height: 1.2; margin-bottom: 1rem; }
  .post-desc { color: rgba(255,255,255,0.75); font-size: 1.0625rem; line-height: 1.65; margin-bottom: 1.25rem; }
  .post-author { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 1rem; }
  .post-author span { color: rgba(255,255,255,0.75); font-size: 0.875rem; }
  .post-author strong { color: rgba(255,255,255,0.9); }
  .author-avatar-sm { width: 32px; height: 32px; border-radius: 50%; background: rgba(243,156,18,0.3); color: #E8B44F; display: flex; align-items: center; justify-content: center; font-family: 'Playfair Display', serif; font-weight: 700; font-size: 0.875rem; }
  .post-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .post-tag { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.8); font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.75rem; border-radius: 9999px; }
  .post-hero-wave { line-height: 0; }
  .post-hero-wave svg { width: 100%; height: 50px; display: block; }

  .post-layout { display: grid; grid-template-columns: 1fr 320px; gap: 3.5rem; align-items: start; }
  .post-content { background: white; border-radius: 20px; padding: 3rem; box-shadow: 0 4px 20px rgba(15,61,82,0.06); }
  .post-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
  .sidebar-card { background: white; border-radius: 16px; padding: 1.5rem; border: 1px solid rgba(189,195,199,0.4); box-shadow: 0 2px 10px rgba(15,61,82,0.05); }
  .sidebar-card h3 { font-family: 'Playfair Display', serif; font-size: 1.0625rem; color: #1B5E7F; margin-bottom: 1rem; padding-bottom: 0.625rem; border-bottom: 1px solid rgba(189,195,199,0.4); }
  .sidebar-author { display: flex; gap: 0.75rem; align-items: center; margin-bottom: 0.875rem; }
  .author-avatar-lg { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #1B5E7F, #2E8BA8); color: white; display: flex; align-items: center; justify-content: center; font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.25rem; flex-shrink: 0; }
  .author-name-lg { font-weight: 600; color: #1B5E7F; font-size: 0.9375rem; }
  .author-role { font-size: 0.8125rem; color: #6B7A8D; }
  .author-bio { font-size: 0.875rem; color: #6B7A8D; line-height: 1.6; margin-bottom: 1rem; }
  .sidebar-link { font-size: 0.875rem; font-weight: 600; color: #1B5E7F; text-decoration: none; transition: color 0.2s; }
  .sidebar-link:hover { color: #F39C12; }
  .sidebar-cta { background: linear-gradient(135deg, #1B5E7F, #0F3D52); color: white; }
  .sidebar-cta h3 { color: #E8B44F !important; border-color: rgba(255,255,255,0.15) !important; }
  .sidebar-cta p { color: rgba(255,255,255,0.8); font-size: 0.875rem; margin-bottom: 1.25rem; }
  .sidebar-tibetan { font-size: 0.875rem; color: rgba(255,255,255,0.45); margin-bottom: 0.375rem; display: block; }
  .sidebar-btn { width: 100%; justify-content: center; margin-bottom: 0.75rem; }
  .sidebar-phone { display: block; text-align: center; font-size: 0.875rem; color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s; }
  .sidebar-phone:hover { color: #E8B44F; }
  .sidebar-links-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem; }
  .sidebar-links-list a { font-size: 0.875rem; color: #1B5E7F; text-decoration: none; padding-left: 1rem; position: relative; line-height: 1.4; transition: color 0.2s, padding-left 0.2s; }
  .sidebar-links-list a::before { content: '→'; position: absolute; left: 0; }
  .sidebar-links-list a:hover { color: #F39C12; padding-left: 1.25rem; }

  @media (max-width: 900px) {
    .post-layout { grid-template-columns: 1fr; }
    .post-sidebar { order: -1; }
    .post-content { padding: 2rem 1.5rem; }
  }
</style>
