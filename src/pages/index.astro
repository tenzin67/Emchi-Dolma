---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import ConditionCard from '../components/ConditionCard.astro';
import services from '../content/services.json';
import testimonials from '../content/testimonials.json';
import conditions from '../content/conditions.json';

// Blog posts preview
const postModules = import.meta.glob('./blog/*.md', { eager: true }) as Record<string, any>;
const recentPosts = Object.entries(postModules)
  .map(([filepath, mod]) => ({ ...mod, slug: filepath.split('/').pop()?.replace('.md', '') ?? '' }))
  .sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime())
  .slice(0, 3);
---

<BaseLayout 
  title="Home"
  description="Emchi Tsundu Dolma — Tibetan Medicine & Ayurveda practitioner in Werribee, VIC. Sowa Rigpa healing for body, mind & spirit. Book a consultation today."
>

  <!-- ===== HERO ===== -->
  <section class="hero" aria-labelledby="hero-heading">
    <!-- Decorative background blobs -->
    <div class="hero-blob hero-blob--1" aria-hidden="true"></div>
    <div class="hero-blob hero-blob--2" aria-hidden="true"></div>
    
    <!-- Corner patterns -->
    <div class="corner-pattern corner-tl" aria-hidden="true">
      <img src="/images/patterns/tibetan-border.svg" alt="" width="120" height="120" />
    </div>
    <div class="corner-pattern corner-tr" aria-hidden="true">
      <img src="/images/patterns/tibetan-border.svg" alt="" width="120" height="120" />
    </div>

    <div class="container hero-inner">
      <!-- Medicine Buddha -->
      <div class="hero-image-wrap" aria-hidden="true">
        <div class="pulse-ring pulse-ring--1"></div>
        <div class="pulse-ring pulse-ring--2"></div>
        <img 
          src="/images/medicine-buddha.png" 
          alt="Medicine Buddha — Sangye Menla"
          class="hero-buddha"
          width="320"
          height="320"
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <!-- Hero content -->
      <div class="hero-content">
        <p class="hero-tibetan tibetan-script hero-text">སོ་རིག་ — སོ་བ་རིགས་པ།</p>
        
        <h1 id="hero-heading" class="hero-title hero-text">
          TibetanSorig
        </h1>
        
        <p class="hero-tagline hero-text">Ancient Wisdom for Modern Healing</p>

        <div class="hero-divider hero-text" aria-hidden="true">
          <span></span>
          <span class="divider-om animate-om-glow">ཨོཾ་</span>
          <span></span>
        </div>

        <blockquote class="hero-quote hero-text">
          <p>"As long as beings are sick, until their illness is cured,<br/>
          may I become the medicine, the physician,<br/>
          and the one who nurses and cares for them."</p>
          <footer>— Medicine Buddha Prayer</footer>
        </blockquote>

        <p class="hero-practitioner hero-text">
          <strong>Emchi Tsundu Dolma</strong> — Tibetan Medicine & Ayurveda Consultant<br/>
          <span>Werribee, VIC · By appointment · 0458 494 785</span>
        </p>

        <div class="hero-actions hero-text">
          <a href="/contact" class="btn btn-secondary" id="hero-book-btn">
            Book a Consultation
          </a>
          <a href="/services" class="btn btn-outline" id="hero-services-btn">
            Our Services
          </a>
        </div>
      </div>
    </div>


  </section>


  <!-- ===== ABOUT STRIP ===== -->
  <section class="about-strip section-sm" aria-label="About Emchi Tsundu Dolma">
    <div class="container">
      <div class="about-strip-inner">
        <div class="about-strip-icon reveal" aria-hidden="true">🌿</div>
        <div class="about-strip-text reveal delay-1">
          <h2>Emchi Tsundu Dolma</h2>
          <p>
            Graduate of <strong>Men-Tsee-Khang</strong>, Dharamshala, India — the principal institution of Tibetan Medicine. 
            With over <strong>10 years</strong> of experience combining Sowa Rigpa and Ayurveda, Emchi brings authentic ancient healing to Werribee and Melbourne.
          </p>
        </div>
        <a href="/about" class="btn btn-primary reveal delay-2" id="about-link">
          Learn More About Emchi →
        </a>
      </div>
    </div>
  </section>


  <!-- ===== SERVICES SECTION ===== -->
  <section class="section bg-cream" id="services" aria-labelledby="services-heading">
    <div class="container">
      <h2 id="services-heading" class="section-title reveal">Our Treatments</h2>
      <div class="section-divider reveal delay-1" aria-hidden="true">
        <span></span><span></span>
      </div>
      <p class="section-subtitle reveal delay-2">
        Comprehensive Sowa Rigpa treatments rooted in 2,500 years of Tibetan healing wisdom, 
        personalised to your unique constitution.
      </p>

      <div class="grid-3">
        {services.map((service, i) => (
          <ServiceCard
            tibetanName={service.tibetanName}
            englishName={service.englishName}
            subtitle={service.subtitle}
            description={service.description}
            icon={service.icon}
            benefits={service.benefits}
            href="/contact"
            delay={i * 75}
          />
        ))}
      </div>

      <div class="section-cta reveal">
        <a href="/services" class="btn btn-primary" id="all-services-btn">View All Treatments →</a>
      </div>
    </div>
  </section>


  <!-- ===== CONDITIONS SECTION ===== -->
  <section class="section" style="background: white;" aria-labelledby="conditions-heading">
    <div class="container">
      <div class="conditions-inner">
        <div class="conditions-header reveal-left">
          <h2 id="conditions-heading" class="section-title" style="text-align: left;">
            What Can Tibetan Medicine Help With?
          </h2>
          <div class="section-divider" style="justify-content: flex-start;" aria-hidden="true">
            <span></span><span></span>
          </div>
          <p class="section-subtitle" style="text-align: left; margin: 0;">
            Sowa Rigpa addresses root causes — not just symptoms. These are some of the conditions 
            that respond beautifully to traditional Tibetan healing.
          </p>
          <a href="/contact" class="btn btn-secondary" style="margin-top: 2rem;" id="conditions-book-btn">
            Book a Consultation
          </a>
        </div>

        <div class="conditions-grid">
          {conditions.map((c, i) => (
            <ConditionCard
              condition={c.condition}
              icon={c.icon}
              description={c.description}
              delay={i * 60}
            />
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ===== TESTIMONIALS SECTION ===== -->
  <section class="section" style="background: #F5F1E8;" aria-labelledby="testimonials-heading">
    <div class="container">
      <h2 id="testimonials-heading" class="section-title reveal">Voices of Healing</h2>
      <div class="section-divider reveal delay-1" aria-hidden="true"><span></span><span></span></div>
      <p class="section-subtitle reveal delay-2">
        Real stories from people whose lives have been transformed through the wisdom of Tibetan Medicine.
      </p>

      <div class="grid-3">
        {testimonials.map((t, i) => (
          <TestimonialCard
            quote={t.quote}
            author={t.author}
            location={t.location}
            condition={t.condition}
            rating={t.rating}
            delay={i * 100}
          />
        ))}
      </div>
    </div>
  </section>


  <!-- ===== BLOG PREVIEW ===== -->
  {recentPosts.length > 0 && (
    <section class="section" style="background: white;" aria-labelledby="blog-heading">
      <div class="container">
        <h2 id="blog-heading" class="section-title reveal">Wisdom & Insights</h2>
        <div class="section-divider reveal delay-1" aria-hidden="true"><span></span><span></span></div>
        <p class="section-subtitle reveal delay-2">
          Explore the philosophy and practice of Tibetan Medicine through Emchi's writings.
        </p>

        <div class="grid-3">
          {recentPosts.map((post, i) => (
            <article class="blog-card reveal" style={`transition-delay: ${i * 80}ms`}>
              <div class="blog-card-meta">
                <time datetime={post.frontmatter.pubDate}>
                  {new Date(post.frontmatter.pubDate).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
              </div>
              <h3 class="blog-card-title">
                <a href={`/blog/${post.slug}`}>
                  {post.frontmatter.title}
                </a>
              </h3>
              <p class="blog-card-desc">{post.frontmatter.description}</p>
              <a href={`/blog/${post.slug}`} class="blog-read-more">
                Read Article →
              </a>
            </article>
          ))}
        </div>

        <div class="section-cta reveal">
          <a href="/blog" class="btn btn-primary" id="all-posts-btn">View All Articles →</a>
        </div>
      </div>
    </section>
  )}


  <!-- ===== CTA BANNER ===== -->
  <section class="cta-banner" aria-labelledby="cta-heading">
    <div class="cta-blob" aria-hidden="true"></div>
    <div class="container cta-inner">
      <div class="cta-text">
        <p class="cta-tibetan tibetan-script reveal">ལུས་སེམས་གཉིས་ཀ་གཞན་བཟང་འགྱུར།</p>
        <h2 id="cta-heading" class="cta-title reveal delay-1">
          Begin Your Healing Journey Today
        </h2>
        <p class="cta-desc reveal delay-2">
          Every healing journey begins with a single step. Book your initial consultation 
          and discover what Tibetan Medicine can do for you.
        </p>
      </div>
      <div class="cta-actions reveal delay-3">
        <a href="/contact" class="btn btn-secondary" id="cta-book-btn">Book a Consultation</a>
        <a href="tel:+61458494785" class="btn btn-outline" id="cta-call-btn">Call 0458 494 785</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    background: linear-gradient(135deg, #0F3D52 0%, #1B5E7F 50%, #2E8BA8 100%);
    position: relative;
    overflow: hidden;
    padding: 5rem 0 0;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .hero-blob--1 {
    width: 500px; height: 500px;
    background: rgba(243, 156, 18, 0.12);
    top: -100px; right: -100px;
    animation: breathe 8s ease-in-out infinite;
  }
  .hero-blob--2 {
    width: 400px; height: 400px;
    background: rgba(255,255,255, 0.06);
    bottom: 50px; left: -80px;
    animation: breathe 10s ease-in-out 2s infinite;
  }

  .corner-pattern {
    position: absolute;
    opacity: 0.2;
    pointer-events: none;
  }
  .corner-tl { top: 0; left: 0; }
  .corner-tr { top: 0; right: 0; transform: scaleX(-1); }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding-bottom: 3rem;
  }

  /* Buddha image */
  .hero-image-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pulse-ring {
    position: absolute;
    border-radius: 50%;
    border: 2px solid rgba(243, 156, 18, 0.3);
    animation: pulseRing 3s ease-out infinite;
  }
  .pulse-ring--1 { width: 300px; height: 300px; animation-delay: 0s; }
  .pulse-ring--2 { width: 380px; height: 380px; animation-delay: 1.2s; }

  @keyframes pulseRing {
    0%   { transform: scale(0.85); opacity: 0.6; }
    70%  { transform: scale(1.1);  opacity: 0; }
    100% { opacity: 0; }
  }

  .hero-buddha {
    width: 320px;
    height: 320px;
    object-fit: contain;
    border-radius: 50%;
    box-shadow: 0 24px 64px rgba(0,0,0,0.35), 0 0 60px rgba(243, 156, 18, 0.2);
    animation: floatIn 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards,
               gentleFloat 7s ease-in-out 1.4s infinite;
    opacity: 0;
    background: rgba(255,255,255,0.05);
  }

  @keyframes floatIn {
    from { opacity: 0; transform: translateY(40px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes gentleFloat {
    0%, 100% { transform: translateY(0) rotate(-0.5deg); }
    50%       { transform: translateY(-18px) rotate(0.5deg); }
  }

  /* Hero content */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero-text {
    animation: textFadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) both;
    opacity: 0;
  }
  .hero-text:nth-child(1)  { animation-delay: 0.2s; }
  .hero-text:nth-child(2)  { animation-delay: 0.4s; }
  .hero-text:nth-child(3)  { animation-delay: 0.6s; }
  .hero-text:nth-child(4)  { animation-delay: 0.75s; }
  .hero-text:nth-child(5)  { animation-delay: 0.9s; }
  .hero-text:nth-child(6)  { animation-delay: 1.05s; }
  .hero-text:nth-child(7)  { animation-delay: 1.2s; }

  @keyframes textFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-tibetan {
    font-size: 1.25rem;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.12em;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    color: white;
    font-family: 'Playfair Display', serif;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .hero-tagline {
    font-size: 1.25rem;
    color: #E8B44F;
    font-weight: 500;
    font-style: italic;
  }

  .hero-divider {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }
  .hero-divider span:not(.divider-om) {
    height: 1px;
    flex: 1;
    max-width: 60px;
    background: rgba(255,255,255,0.25);
  }
  .divider-om {
    font-size: 1.5rem;
    color: #E8B44F;
  }

  .hero-quote {
    border-left: 3px solid rgba(243, 156, 18, 0.6);
    padding-left: 1.25rem;
  }
  .hero-quote p {
    color: rgba(255,255,255,0.85);
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1.7;
  }
  .hero-quote footer {
    margin-top: 0.5rem;
    color: rgba(255,255,255,0.5);
    font-size: 0.8125rem;
  }

  .hero-practitioner {
    color: rgba(255,255,255,0.9);
    font-size: 0.9375rem;
  }
  .hero-practitioner strong { color: #E8B44F; }
  .hero-practitioner span  { color: rgba(255,255,255,0.65); font-size: 0.875rem; }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }



  /* ===== ABOUT STRIP ===== */
  .about-strip {
    background: linear-gradient(90deg, #1B5E7F, #2E8BA8);
    color: white;
    padding: 2.5rem 0;
  }
  .about-strip-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .about-strip-icon { font-size: 3rem; flex-shrink: 0; }
  .about-strip-text { flex: 1; min-width: 240px; }
  .about-strip-text h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.375rem;
    color: white;
    margin-bottom: 0.375rem;
  }
  .about-strip-text p { color: rgba(255,255,255,0.85); font-size: 0.9375rem; line-height: 1.6; }
  .about-strip-text strong { color: #E8B44F; }

  /* ===== CONDITIONS ===== */
  .conditions-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .conditions-header { padding-top: 1rem; }
  .conditions-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  /* ===== BLOG CARDS ===== */
  .blog-card {
    background: #F5F1E8;
    border-radius: 16px;
    padding: 1.75rem;
    border: 1px solid rgba(189, 195, 199, 0.4);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .blog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 32px rgba(27, 94, 127, 0.1);
  }
  .blog-card-meta {
    font-size: 0.8125rem;
    color: #6B7A8D;
    font-weight: 500;
  }
  .blog-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1875rem;
    line-height: 1.3;
  }
  .blog-card-title a {
    color: #1B5E7F;
    text-decoration: none;
    transition: color 0.2s;
  }
  .blog-card-title a:hover { color: #F39C12; }
  .blog-card-desc {
    font-size: 0.9375rem;
    color: #6B7A8D;
    line-height: 1.6;
    flex: 1;
  }
  .blog-read-more {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1B5E7F;
    text-decoration: none;
    transition: color 0.2s, letter-spacing 0.2s;
    width: fit-content;
  }
  .blog-read-more:hover { color: #F39C12; letter-spacing: 0.01em; }

  .section-cta { text-align: center; margin-top: 3rem; }

  /* ===== CTA BANNER ===== */
  .cta-banner {
    background: linear-gradient(135deg, #1B5E7F 0%, #0F3D52 100%);
    padding: 5rem 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-blob {
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: rgba(243, 156, 18, 0.06);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    filter: blur(60px);
    pointer-events: none;
  }
  .cta-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }
  .cta-tibetan { font-size: 1rem; color: rgba(255,255,255,0.5); }
  .cta-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: white;
    max-width: 640px;
    line-height: 1.2;
  }
  .cta-desc { color: rgba(255,255,255,0.75); max-width: 520px; font-size: 1.0625rem; }
  .cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      padding-top: 2rem;
    }
    .hero-image-wrap { order: -1; }
    .hero-buddha { width: 220px; height: 220px; }
    .hero-divider, .hero-actions { justify-content: center; }
    .hero-quote { border-left: none; border-top: 3px solid rgba(243,156,18,0.5); padding: 1rem 0 0; }
    .conditions-inner { grid-template-columns: 1fr; gap: 2rem; }
  }
  @media (max-width: 640px) {
    .about-strip-inner { flex-direction: column; text-align: center; }
  }
</style>
