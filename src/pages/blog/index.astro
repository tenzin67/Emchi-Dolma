---
import BaseLayout from '../../layouts/BaseLayout.astro';

const postModules = import.meta.glob('./*.md', { eager: true }) as Record<string, any>;
const posts = Object.entries(postModules)
  .map(([filepath, mod]) => ({ ...mod, slug: filepath.split('/').pop()?.replace('.md', '') ?? '' }))
  .sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());
---

<BaseLayout 
  title="Blog — Tibetan Medicine Wisdom"
  description="Articles and insights on Tibetan Medicine, Sowa Rigpa, the three Nyepas, pulse diagnosis, and holistic healing by Emchi Tsundu Dolma."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="page-hero-tibetan tibetan-script">ཡི་གེ་སྨན་གྱི།</p>
      <h1 class="page-hero-title">Wisdom & Insights</h1>
      <p class="page-hero-subtitle">Exploring the philosophy and practice of Tibetan Medicine</p>
    </div>
    <div class="page-hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none">
        <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#F5F1E8"/>
      </svg>
    </div>
  </section>

  <section class="section" style="background: #F5F1E8;">
    <div class="container">
      {posts.length === 0 ? (
        <p style="text-align: center; color: #6B7A8D; font-size: 1.125rem; padding: 4rem 0;">
          Articles coming soon. Check back shortly!
        </p>
      ) : (
        <div class="blog-list">
          {posts.map((post, i) => (
              <article class="blog-list-item reveal" style={`transition-delay: ${i * 80}ms`}>
                <div class="blog-item-meta">
                  <time datetime={post.frontmatter.pubDate}>
                    {new Date(post.frontmatter.pubDate).toLocaleDateString('en-AU', {
                      day: 'numeric', month: 'long', year: 'numeric'
                    })}
                  </time>
                  {post.frontmatter.tags?.slice(0, 2).map((tag: string) => (
                    <span class="blog-tag">{tag}</span>
                  ))}
                </div>
                <h2 class="blog-item-title">
                  <a href={`/blog/${post.slug}`}>{post.frontmatter.title}</a>
                </h2>
                <p class="blog-item-desc">{post.frontmatter.description}</p>
                <div class="blog-item-footer">
                  <span class="blog-author">By {post.frontmatter.author}</span>
                  <a href={`/blog/${post.slug}`} class="blog-read-more">Read Article →</a>
                </div>
              </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #1B5E7F, #0F3D52);
    padding: 5rem 0 2rem;
    text-align: center;
    overflow: hidden;
  }
  .page-hero-tibetan { font-size: 1.25rem; color: rgba(255,255,255,0.55); display: block; margin-bottom: 0.75rem; }
  .page-hero-title { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 3rem); color: white; margin-bottom: 0.75rem; }
  .page-hero-subtitle { color: #E8B44F; font-style: italic; font-size: 1.125rem; }
  .page-hero-wave { line-height: 0; }
  .page-hero-wave svg { width: 100%; height: 50px; display: block; }

  .blog-list { display: flex; flex-direction: column; gap: 2rem; max-width: 800px; margin: 0 auto; }

  .blog-list-item {
    background: white;
    border-radius: 16px;
    padding: 2.25rem;
    border: 1px solid rgba(189, 195, 199, 0.4);
    box-shadow: 0 2px 12px rgba(15, 61, 82, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .blog-list-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(27, 94, 127, 0.1);
  }

  .blog-item-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.875rem;
  }
  .blog-item-meta time { font-size: 0.875rem; color: #6B7A8D; }
  .blog-tag {
    background: rgba(27, 94, 127, 0.1);
    color: #1B5E7F;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    text-transform: capitalize;
  }

  .blog-item-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4375rem;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }
  .blog-item-title a { color: #1B5E7F; text-decoration: none; transition: color 0.2s; }
  .blog-item-title a:hover { color: #F39C12; }

  .blog-item-desc { color: #6B7A8D; font-size: 0.9375rem; line-height: 1.65; margin-bottom: 1.25rem; }

  .blog-item-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid rgba(189, 195, 199, 0.4);
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .blog-author { font-size: 0.875rem; color: #6B7A8D; }
  .blog-read-more {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1B5E7F;
    text-decoration: none;
    transition: color 0.2s, letter-spacing 0.2s;
  }
  .blog-read-more:hover { color: #F39C12; }
</style>
