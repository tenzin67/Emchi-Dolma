---
interface Props {
  tibetanName: string;
  englishName: string;
  subtitle?: string;
  description: string;
  icon: string;
  benefits?: string[];
  href?: string;
  delay?: number;
  image?: string;
}

const { 
  tibetanName, 
  englishName, 
  subtitle, 
  description, 
  icon, 
  benefits = [],
  href = '/contact',
  delay = 0,
  image
} = Astro.props;
---

<article 
  class={`service-card reveal${image ? ' has-image' : ''}`}
  style={`transition-delay: ${delay}ms`}
  aria-label={`${englishName} treatment`}
>
  <div class="card-accent"></div>

  {image ? (
    <div class="card-image-wrap">
      <img 
        src={image} 
        alt={`${englishName} treatment`} 
        class="card-image"
        loading="lazy"
        decoding="async"
      />
      <div class="card-image-overlay"></div>
      <span class="card-icon-badge" aria-hidden="true">{icon}</span>
    </div>
  ) : (
    <div class="card-icon" aria-hidden="true">{icon}</div>
  )}
  
  <p class="card-tibetan tibetan-script">{tibetanName}</p>
  
  <h3 class="card-title">{englishName}</h3>
  
  {subtitle && <p class="card-subtitle">{subtitle}</p>}
  
  <p class="card-description">{description}</p>

  {benefits.length > 0 && (
    <ul class="card-benefits" aria-label="Benefits">
      {benefits.slice(0, 3).map(b => (
        <li>
          <span class="benefit-dot" aria-hidden="true"></span>
          {b}
        </li>
      ))}
    </ul>
  )}

  <a href={href} class="card-link" aria-label={`Learn more about ${englishName}`}>
    Learn More
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </a>
</article>

<style>
  .service-card {
    position: relative;
    background: white;
    border-radius: 16px;
    border: 1px solid rgba(189, 195, 199, 0.5);
    box-shadow: 0 2px 12px rgba(15, 61, 82, 0.06);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.35s ease,
                border-color 0.3s ease;
  }

  /* Cards without image keep the old padding */
  .service-card:not(.has-image) {
    padding: 2rem 1.75rem 1.75rem;
  }

  /* Cards with image: only pad the content below the photo */
  .service-card.has-image {
    padding: 0 0 1.75rem;
  }
  .service-card.has-image .card-tibetan,
  .service-card.has-image .card-title,
  .service-card.has-image .card-subtitle,
  .service-card.has-image .card-description,
  .service-card.has-image .card-benefits,
  .service-card.has-image .card-link {
    padding-left: 1.75rem;
    padding-right: 1.75rem;
  }
  .service-card.has-image .card-tibetan {
    margin-top: 1rem;
  }

  .service-card:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow: 0 20px 40px rgba(27, 94, 127, 0.14);
    border-color: rgba(27, 94, 127, 0.25);
  }

  /* Top accent line */
  .card-accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #F39C12, #1B5E7F, #2E8BA8);
    background-size: 200% 100%;
    z-index: 2;
    transition: background-position 0.4s ease;
  }
  .service-card:hover .card-accent {
    background-position: 100% 0;
  }

  /* ── Image header ── */
  .card-image-wrap {
    position: relative;
    width: 100%;
    height: 190px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s ease;
  }
  .service-card:hover .card-image {
    transform: scale(1.06);
  }
  .card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(15, 61, 82, 0.45) 100%
    );
  }
  /* Small icon badge on top of the photo */
  .card-icon-badge {
    position: absolute;
    bottom: 0.75rem;
    right: 1rem;
    font-size: 1.75rem;
    line-height: 1;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.35));
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .service-card:hover .card-icon-badge {
    transform: rotate(10deg) scale(1.2);
  }

  /* Icon (no-image cards) */
  .card-icon {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 0.25rem;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: inline-block;
    width: fit-content;
  }
  .service-card:hover .card-icon {
    transform: rotate(10deg) scale(1.15);
  }

  /* Tibetan name */
  .card-tibetan {
    font-size: 1rem;
    color: #6B7A8D;
    letter-spacing: 0.1em;
  }

  /* Title */
  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1B5E7F;
    line-height: 1.3;
    margin: 0;
  }

  /* Subtitle */
  .card-subtitle {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #F39C12;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Description */
  .card-description {
    font-size: 0.9375rem;
    color: #6B7A8D;
    line-height: 1.6;
    flex: 1;
    margin: 0.25rem 0;
  }

  /* Benefits */
  .card-benefits {
    list-style: none;
    margin: 0.25rem 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .card-benefits li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #2C3E50;
  }
  .benefit-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: linear-gradient(135deg, #F39C12, #E8B44F);
    flex-shrink: 0;
  }

  /* CTA link */
  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.5rem;
    color: #1B5E7F;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: gap 0.25s, color 0.25s;
    width: fit-content;
  }
  .card-link:hover {
    color: #F39C12;
    gap: 0.625rem;
  }
  .card-link svg {
    transition: transform 0.25s;
  }
  .card-link:hover svg {
    transform: translateX(3px);
  }
</style>
