---
interface Props {
  quote: string;
  author: string;
  location?: string;
  condition: string;
  rating?: number;
  delay?: number;
}

const { quote, author, location, condition, rating = 5, delay = 0 } = Astro.props;
---

<article 
  class="testimonial-card reveal"
  style={`transition-delay: ${delay}ms`}
  aria-label={`Testimonial from ${author}`}
>
  <div class="card-quote-mark" aria-hidden="true">"</div>
  
  <!-- Stars -->
  <div class="stars" role="img" aria-label={`${rating} out of 5 stars`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg 
        class={`star ${i < rating ? 'filled' : 'empty'}`}
        style={`animation-delay: ${delay + i * 80}ms`}
        viewBox="0 0 24 24" 
        width="18" height="18"
        aria-hidden="true"
      >
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
      </svg>
    ))}
  </div>

  <!-- Quote -->
  <blockquote class="testimonial-quote">
    <p>"{quote}"</p>
  </blockquote>

  <!-- Author -->
  <footer class="testimonial-author">
    <div class="author-avatar" aria-hidden="true">
      {author.charAt(0)}
    </div>
    <div class="author-info">
      <p class="author-name">{author}</p>
      {location && <p class="author-location">{location}</p>}
      <span class="author-condition">{condition}</span>
    </div>
  </footer>
</article>

<style>
  .testimonial-card {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    position: relative;
    border: 1px solid rgba(189, 195, 199, 0.4);
    box-shadow: 0 2px 12px rgba(15, 61, 82, 0.06);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .testimonial-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 32px rgba(27, 94, 127, 0.12);
  }

  /* Decorative quote mark */
  .card-quote-mark {
    position: absolute;
    top: -0.5rem;
    left: 1.25rem;
    font-size: 5rem;
    font-family: 'Playfair Display', serif;
    color: rgba(27, 94, 127, 0.07);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  /* Stars */
  .stars {
    display: flex;
    gap: 0.25rem;
  }
  .star {
    animation: starBurst 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .star.filled path { fill: #F39C12; stroke: #F39C12; }
  .star.empty path { fill: #ECF0F1; stroke: #BDC3C7; }

  @keyframes starBurst {
    0%   { opacity: 0; transform: scale(0) rotate(-180deg); }
    100% { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  /* Quote */
  .testimonial-quote {
    flex: 1;
  }
  .testimonial-quote p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #2C3E50;
    font-style: italic;
  }

  /* Author */
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(189, 195, 199, 0.5);
  }
  .author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1B5E7F, #2E8BA8);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 1.125rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .author-info { display: flex; flex-direction: column; gap: 0.125rem; }
  .author-name { font-weight: 600; color: #1B5E7F; font-size: 0.9375rem; }
  .author-location { font-size: 0.8125rem; color: #6B7A8D; }
  .author-condition {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: #F39C12;
    background: rgba(243, 156, 18, 0.1);
    border-radius: 9999px;
    padding: 0.125rem 0.625rem;
    width: fit-content;
    margin-top: 0.125rem;
  }
</style>
